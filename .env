# Redpanda
REDPANDA_BROKERS=redpanda:9092

# TimescaleDB
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=telemetry
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Simulator
BASE_TICK_MS=200
JITTER_MS=30

# Consumer
DISCONNECTION_THRESHOLD_S=30
ALERT_COOLDOWN_S=300
ISOLATION_FOREST_MIN_READINGS=50
ISOLATION_FOREST_RETRAIN_EVERY=100

# Dashboard
DASHBOARD_REFRESH_SECONDS=10